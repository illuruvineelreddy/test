# Environment Configuration for Project Astra

# Application
APP_NAME=Project Astra
DEBUG=true
ENVIRONMENT=development

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Security - CHANGE IN PRODUCTION
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/astra_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Trading Mode (paper, semi_auto, full_auto)
TRADING_MODE=paper

# Capital & Risk
INITIAL_CAPITAL=100000
RISK_PER_TRADE_PCT=1.0
DAILY_LOSS_LIMIT_PCT=3.0
MAX_CONSECUTIVE_LOSSES=5

# Broker Configuration (Example: Zerodha)
# BROKER_API_KEY=your_api_key
# BROKER_API_SECRET=your_api_secret
# BROKER_ACCESS_TOKEN=your_access_token

# Telegram Alerts (Optional)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Logging
LOG_LEVEL=INFO

# Upstox Broker Configuration
# WARNING: Never commit actual credentials to Git
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_ACCESS_TOKEN=your_access_token_here
UPSTOX_ENVIRONMENT=live  # or 'test' for sandbox
